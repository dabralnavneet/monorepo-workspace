{
  "name": "monorepo-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Centralized monorepo for all standard side-projects and apps",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:callbackos": "turbo dev --filter=@callbackos/*",
    "dev:callbackos:web": "turbo dev --filter=@callbackos/web",
    "dev:callbackos:server": "turbo dev --filter=@callbackos/server",
    "db:callbackos:generate": "turbo db:generate --filter=@callbackos/database",
    "db:callbackos:push": "turbo db:push --filter=@callbackos/database",
    "db:callbackos:migrate": "turbo db:migrate --filter=@callbackos/database",
    "clean": "turbo clean",
    "dev:digital-twin": "turbo dev --filter=@digital-twin/*",
    "dev:civic": "turbo dev --filter=@civic-navigator/web"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "turbo": "^2.8.14"
  }
}
