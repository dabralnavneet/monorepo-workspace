---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/navigation';
import { ChapterDivider } from '../../components/StoryComponents';

// Get all markdown posts in this directory
const posts = await Astro.glob('./*.md');

// Sort by date (newest first)
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---
<Layout title="Thoughts | Navneet Dabral">
  <Navigation client:load />
  
  <div class="paper-layer-texture" aria-hidden="true"></div>
  <div class="paper-vignette" aria-hidden="true"></div>

  <main class="relative z-10 w-full pt-32 pb-40 min-h-screen text-stone-800 selection:bg-stone-800/10">
    <div class="max-w-4xl mx-auto px-6">
      
      <a href="/" class="inline-flex items-center text-sm font-mono text-stone-400 hover:text-stone-800 transition-colors mb-16 uppercase tracking-widest">
        ← Back to Portfolio
      </a>

      <ChapterDivider
        client:load
        number="Archive"
        title="My Thoughts."
        subtitle="Writing helps me think. Observations on engineering, design, and building products that actually matter."
      />

      <div class="mt-20 flex flex-col gap-12 sm:gap-16 pl-4 border-l-2 border-stone-200 ml-2">
        {sortedPosts.map((post) => (
          <article class="relative group">
            {/* Timeline dot */}
            <div class="absolute -left-[23px] top-6 w-3 h-3 rounded-full bg-[#f5f1ea] border-2 border-stone-300 group-hover:border-stone-800 transition-colors duration-300 z-10"></div>
            
            <a href={post.url} class="block pl-8">
              <div class="flex flex-col md:flex-row md:items-baseline justify-between gap-1 sm:gap-2 mb-2">
                <span class="font-mono text-[10px] sm:text-xs text-stone-400 uppercase tracking-widest">{post.frontmatter.date}</span>
                <span class="font-mono text-[10px] text-stone-300 uppercase tracking-widest">{post.frontmatter.readTime}</span>
              </div>
              
              <h2 class="text-2xl sm:text-4xl font-bold tracking-tight text-stone-800 mb-4 group-hover:underline decoration-1 underline-offset-4 transition-all" style="font-family: 'Google Sans Flex', sans-serif;">
                {post.frontmatter.title}
              </h2>
              
              <p class="text-stone-500 text-base sm:text-lg leading-relaxed max-w-2xl">
                {post.frontmatter.description}
              </p>
              
              <div class="mt-6 font-mono text-xs text-stone-800 uppercase tracking-widest font-medium flex items-center gap-2 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                Read Essay <span class="text-lg">→</span>
              </div>
            </a>
          </article>
        ))}
        
        {sortedPosts.length === 0 && (
          <p class="text-stone-400 italic pl-8">No thoughts published yet. Check back soon.</p>
        )}
      </div>
    </div>
  </main>
</Layout>
